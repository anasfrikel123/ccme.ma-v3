# ─────────────────────────────────────────────────────────────────────────────
# Cabinet CCME — environment variables
#
# Copy this file to `.env` for local dev, and set the same keys in Cloudflare Pages
# (Settings → Environment variables) before the production deploy.
# `PUBLIC_*` keys are bundled into the client build; never put a server-only
# secret behind a `PUBLIC_` prefix.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — Web3Forms public access key for the /contact form.
# Get one in 30 seconds at https://web3forms.com (verify the cabinet email).
# Production builds fail if this is unset (see contact.astro). Set the same key in
# Cloudflare Pages → Settings → Environment variables before deploy.
PUBLIC_WEB3FORMS_KEY=

# OPTIONAL — Google Search Console verification token.
# Only used by /robots.txt + the verification meta tag if you add one.
# Leave empty if not using GSC.
PUBLIC_GSC_TOKEN=

# OPTIONAL — Moroccan business identifiers (ICE, IF, RC, Patente).
# Required on mentions légales and footer for OEC-inscribed cabinets.
# Find these on your RC extract, DGI attestation, or OMPIC fiche.
PUBLIC_CABINET_ICE=
PUBLIC_CABINET_IF=
PUBLIC_CABINET_RC=
PUBLIC_CABINET_PATENTE=
