---
// Google Analytics 4 — Measurement ID G-3C217NHBTM.
// Rendered production-only (see Base.astro) so local dev never pollutes data.
---
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-3C217NHBTM"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-3C217NHBTM');
</script>
<!-- Conversion tracking: phone + WhatsApp clicks (contact-form lead fired in contact.astro) -->
<script is:inline>
  document.addEventListener('click', function (e) {
    var t = e.target;
    var a = t && t.closest ? t.closest('a[href]') : null;
    if (!a || typeof window.gtag !== 'function') return;
    var href = a.getAttribute('href') || '';
    if (href.indexOf('tel:') === 0) {
      window.gtag('event', 'phone_click', { transport_type: 'beacon', link_url: href });
    } else if (href.indexOf('wa.me') !== -1 || href.toLowerCase().indexOf('whatsapp') !== -1) {
      window.gtag('event', 'whatsapp_click', { transport_type: 'beacon', link_url: href });
    }
  }, true);
</script>
