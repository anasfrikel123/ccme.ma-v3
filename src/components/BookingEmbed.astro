---
/**
 * Cal.com booking embed.
 *
 * If `cabinet.calcom.handle` is configured, drops Cal.com's official inline
 * embed loader and renders the picker on the page. If not yet configured,
 * shows a subtle "configure required" hint in dev and a plain telephone
 * fallback in production. The dev message is hidden from real users.
 *
 * Setup:
 *   1. Sign up at cal.com (free tier OK).
 *   2. Create an event type called "Premier échange (30 min)" — slug
 *      `premier-echange-30min`.
 *   3. Set `cabinet.calcom.handle` in src/data/cabinet.ts to your username.
 */
import { cabinet } from '~/data/cabinet';

const handle = cabinet.calcom?.handle?.trim();
const event  = cabinet.calcom?.eventSlug?.trim();
const fullSlug = handle && event ? `${handle}/${event}` : '';
const isConfigured = Boolean(fullSlug);
const isDev = import.meta.env.DEV;
---
<section class="booking" aria-labelledby="booking-heading">
  <div class="container">
    <div class="booking-head reveal">
      <p class="eyebrow eyebrow-gold">Réservation directe</p>
      <h2 id="booking-heading">Choisissez un créneau, on s'occupe du reste.</h2>
      <p class="lede">
        Premier échange de 30 minutes, gratuit, sans engagement. En visio,
        par téléphone ou au cabinet — vous décidez.
      </p>
      <ul class="booking-points">
        <li>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Confirmation immédiate, lien visio inclus
        </li>
        <li>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Réagendable / annulable en un clic
        </li>
        <li>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Pas de carte bancaire, pas d'engagement
        </li>
      </ul>
    </div>

    {isConfigured ? (
      <div class="booking-frame reveal">
        {/* Cal.com inline embed — official snippet pattern. */}
        <div data-cal-link={fullSlug} data-cal-namespace="booking" data-cal-config='{"layout":"month_view"}'></div>
        <noscript>
          <a href={`https://cal.com/${fullSlug}`} class="btn btn-gold" rel="noopener" target="_blank">
            Réserver sur Cal.com →
          </a>
        </noscript>
      </div>
    ) : (
      <div class="booking-fallback reveal">
        <div class="fallback-card">
          <p class="fallback-title">Le calendrier en ligne arrive bientôt.</p>
          <p>En attendant, le plus rapide : un appel direct ou un message WhatsApp. On vous trouve un créneau dans la journée.</p>
          <div class="fallback-actions">
            <a href={cabinet.phone.tel} class="btn btn-gold">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              {cabinet.phone.display}
            </a>
            <a href={cabinet.phone.whatsapp} class="btn btn-ghost" rel="noopener" target="_blank">
              WhatsApp
            </a>
          </div>
        </div>
        {isDev && (
          <p class="config-hint" role="note">
            <strong>Note dev :</strong>
            définissez <code>cabinet.calcom.handle</code> dans
            <code>src/data/cabinet.ts</code> pour activer le calendrier en ligne.
          </p>
        )}
      </div>
    )}
  </div>
</section>

{isConfigured && (
  <script is:inline define:vars={{ fullSlug }}>
    /* Cal.com official inline embed loader — see https://cal.com/docs/embed */
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === "string") {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar);
            p(cal, ["initNamespace", namespace]);
          } else p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");
    Cal("init", "booking", { origin: "https://cal.com" });
    Cal.ns.booking("inline", {
      elementOrSelector: "[data-cal-link='" + fullSlug + "']",
      config: { layout: "month_view", theme: "light" },
      calLink: fullSlug,
    });
    Cal.ns.booking("ui", {
      hideEventTypeDetails: false,
      layout: "month_view",
      cssVarsPerTheme: {
        light: { "cal-brand": "#c8a85a" }
      }
    });
  </script>
)}

<style>
  .booking {
    padding-block: clamp(56px, 7vw, 88px);
    background:
      radial-gradient(800px 360px at 100% 0%, rgba(200, 168, 90, 0.10), transparent 60%),
      var(--paper-2);
    border-block: 1px solid var(--line);
  }
  .booking-head {
    max-width: 60ch;
    margin: 0 auto clamp(28px, 3vw, 40px);
    text-align: center;
  }
  .booking-head .eyebrow { justify-content: center; }
  .booking-head h2 { margin-bottom: 14px; }
  .booking-head .lede { margin: 0 auto 20px; }

  .booking-points {
    list-style: none;
    margin: 0;
    padding: 0;
    display: inline-flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    justify-content: center;
    font-size: 13.5px;
    color: var(--ink-soft);
  }
  .booking-points li {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .booking-points svg { color: var(--gold); flex-shrink: 0; }

  .booking-frame {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: clamp(8px, 1vw, 16px);
    box-shadow: 0 18px 48px -22px rgba(20, 37, 63, 0.18);
    min-height: 560px;
    overflow: hidden;
  }
  .booking-frame [data-cal-link] {
    width: 100%;
    min-height: 560px;
  }

  .booking-fallback {
    display: grid;
    place-items: center;
    gap: 16px;
  }
  .fallback-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: clamp(24px, 3vw, 40px);
    max-width: 520px;
    width: 100%;
    text-align: center;
    box-shadow: 0 14px 36px -18px rgba(20, 37, 63, 0.16);
  }
  .fallback-title {
    font-family: var(--serif);
    font-size: 1.25rem;
    color: var(--ink);
    margin: 0 0 10px;
  }
  .fallback-card p { color: var(--ink-soft); }
  .fallback-actions {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 16px;
  }
  .config-hint {
    font-size: 12.5px;
    color: var(--muted);
    background: var(--paper);
    padding: 10px 14px;
    border: 1px dashed var(--line);
    border-radius: 8px;
    margin: 0;
    max-width: 540px;
  }
  .config-hint code {
    font-family: var(--mono);
    background: rgba(200, 168, 90, 0.16);
    color: var(--accent-deep);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 12px;
  }

  /* ── Dark theme ───────────────────────────────────────
     .booking-frame / .fallback-card are hardcoded #fff; in dark mode the
     text colours flip light, so the white card left them faded and made the
     ghost WhatsApp button white-on-white. Re-tone to the dark surface. */
  :global(:root[data-theme="dark"]) .fallback-card,
  :global(:root[data-theme="dark"]) .booking-frame {
    background: var(--surface);
    border-color: var(--line);
    box-shadow: 0 14px 36px -18px rgba(0, 0, 0, 0.55);
  }
  :global(:root[data-theme="dark"]) .fallback-card .btn-ghost {
    color: var(--ink);
    border-color: color-mix(in oklch, var(--gold) 42%, var(--line));
  }
</style>
