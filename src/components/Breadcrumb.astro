---
interface Crumb { label: string; href?: string; }
interface Props { items: Crumb[]; }
const { items } = Astro.props;
const SITE = 'https://www.ccme.ma';

// Resolve current page URL once so the last (current-page) crumb gets a real `item`
// even when no href is passed, satisfying Google's BreadcrumbList guidelines.
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const currentUrl = `${SITE}${currentPath}`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((c, i) => {
    const isLast = i === items.length - 1;
    const itemUrl = c.href ? `${SITE}${c.href}` : isLast ? currentUrl : undefined;
    const entry: Record<string, unknown> = {
      '@type': 'ListItem',
      position: i + 1,
      name: c.label,
    };
    if (itemUrl) entry.item = itemUrl;
    return entry;
  }),
};
---
<nav class="breadcrumb" aria-label="Fil d'Ariane">
  <ol>
    {items.map((c, i) => (
      <li>
        {c.href && i < items.length - 1
          ? <a href={c.href}>{c.label}</a>
          : <span aria-current="page">{c.label}</span>}
        {i < items.length - 1 && <span class="sep" aria-hidden="true">›</span>}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<style>
  .breadcrumb { padding-block: 12px; font-size: 13px; color: var(--muted); }
  .breadcrumb ol { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
  .breadcrumb a { color: var(--muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--ink); }
  .sep { opacity: .5; }
</style>
