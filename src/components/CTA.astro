---
import { cabinet } from '~/data/cabinet';
interface Props {
  title?: string;
  text?: string;
  variant?: 'default' | 'compact';
}
const {
  title = 'Premier échange gratuit. Sans engagement.',
  text = "On regarde ensemble vos chiffres, vos obligations, votre fiscalité — et on voit où on peut vous faire gagner du temps. 30 minutes, par téléphone ou au cabinet.",
  variant = 'default'
} = Astro.props;
---
<section class={`cta-band ${variant === 'compact' ? 'cta-compact' : ''}`}>
  <span class="cta-grain" aria-hidden="true"></span>
  <span class="cta-glow cta-glow-1" aria-hidden="true"></span>
  <span class="cta-glow cta-glow-2" aria-hidden="true"></span>
  <div class="container">
    <div class="cta-inner reveal">
      <div class="cta-copy">
        <p class="eyebrow eyebrow-gold">Prendre contact</p>
        <h2>{title}</h2>
        <p class="lede">{text}</p>
      </div>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-gold">Demander un devis</a>
        <a href={cabinet.phone.tel} class="btn btn-ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {cabinet.phone.display}
        </a>
      </div>
    </div>
  </div>
</section>
<style>
  .cta-band {
    background:
      radial-gradient(800px 360px at 100% 0%, rgba(200, 168, 90, 0.18), transparent 60%),
      radial-gradient(700px 320px at 0% 100%, rgba(255, 255, 255, 0.05), transparent 55%),
      linear-gradient(135deg, #0f1c30 0%, var(--ink) 60%, #1a2c4a 100%);
    color: #fff;
    padding-block: clamp(56px, 8vw, 96px);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  /* Subtle film-grain texture for depth — barely perceptible, but breaks the
     flatness of a pure gradient. Pure CSS noise via repeating gradients. */
  .cta-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(1px 1px at 20% 20%, rgba(255,255,255,0.06), transparent 2px),
      radial-gradient(1px 1px at 60% 70%, rgba(255,255,255,0.05), transparent 2px),
      radial-gradient(1px 1px at 80% 30%, rgba(255,255,255,0.04), transparent 2px),
      radial-gradient(1px 1px at 35% 85%, rgba(255,255,255,0.05), transparent 2px);
    background-size: 220px 220px;
    mix-blend-mode: screen;
    opacity: 0.6;
  }
  .cta-glow {
    position: absolute;
    pointer-events: none;
    border-radius: 50%;
    filter: blur(60px);
  }
  .cta-glow-1 {
    top: -180px;
    right: -120px;
    width: 460px;
    height: 460px;
    background: radial-gradient(circle, rgba(200, 168, 90, 0.32) 0%, transparent 70%);
  }
  .cta-glow-2 {
    bottom: -200px;
    left: -150px;
    width: 380px;
    height: 380px;
    background: radial-gradient(circle, rgba(70, 110, 180, 0.18) 0%, transparent 70%);
  }

  .cta-band h2 { color: #fff; max-width: 22ch; margin-bottom: 16px; }
  .cta-band .lede { color: rgba(255,255,255,0.78); max-width: 56ch; margin: 0; }
  .cta-band .eyebrow { color: var(--gold); }

  .cta-inner {
    display: grid;
    grid-template-columns: 1.4fr auto;
    align-items: center;
    gap: clamp(24px, 4vw, 48px);
    position: relative;
    z-index: 1;
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: flex-end;
    align-items: center;
  }

  /* Override .btn-ghost on dark CTA — keep visual hierarchy */
  .cta-band .btn-ghost {
    color: #fff;
    border-color: rgba(255,255,255,0.3);
    backdrop-filter: blur(8px);
    background: rgba(255,255,255,0.04);
  }
  .cta-band .btn-ghost:hover {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.7);
    color: #fff;
  }

  .cta-compact { padding-block: clamp(36px, 5vw, 56px); }

  @media (max-width: 900px) {
    .cta-inner { grid-template-columns: 1fr; }
    .cta-actions { justify-content: flex-start; }
  }
  @media (max-width: 480px) {
    .cta-actions { width: 100%; }
    .cta-actions .btn { flex: 1; justify-content: center; }
  }
</style>
