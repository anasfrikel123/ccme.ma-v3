---
interface QA { q: string; a: string; }
interface Props {
  items: QA[];
  title?: string;
  /**
   * Emit `FAQPage` JSON-LD. After Google's March 2026 structured-data update,
   * FAQ rich results are restricted to pages where Q&A is the primary content.
   * On service / sector / blog pages where the FAQ is supplementary, the
   * markup wins no rich result and dilutes our schema graph — so we ship the
   * visible accordion without it. Set `withSchema={true}` only on a future
   * dedicated `/faq` page (or any page where the FAQ truly is the main body).
   */
  withSchema?: boolean;
}
const { items, title = 'Questions fréquentes', withSchema = false } = Astro.props;

// Strip Astro's .html build suffix so the JSON-LD @id matches the served URL.
const faqPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/$/, '') || '/';
const pageId = `https://ccme.ma${faqPath}`;

const faqPageSchema = withSchema ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${pageId}#faq`,
  inLanguage: 'fr-MA',
  mainEntity: items.map(i => ({
    '@type': 'Question',
    name: i.q,
    acceptedAnswer: { '@type': 'Answer', text: i.a, inLanguage: 'fr-MA' },
  })),
} : null;

/** Speakable hints for AI Mode / voice — emitted even when FAQPage schema is off. */
const faqSpeakableSchema = items.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'WebPageElement',
  '@id': `${pageId}#faq-speakable`,
  name: title,
  isPartOf: { '@id': pageId },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.faq-item summary', '.faq-a'],
  },
} : null;
---
<section class="faq-section" aria-labelledby="faq-title">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow eyebrow-gold">FAQ</p>
      <h2 id="faq-title">{title}</h2>
    </div>
    <div class="faq-list">
      {items.map((it, i) => (
        <details class="faq-item reveal" style={`transition-delay:${i * 60}ms`}>
          <summary>
            <span class="faq-q">{it.q}</span>
            <span class="faq-icon" aria-hidden="true">
              <svg class="faq-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </span>
          </summary>
          <div class="faq-a"><p>{it.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>
{faqPageSchema && <script type="application/ld+json" set:html={JSON.stringify(faqPageSchema)} />}
{faqSpeakableSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSpeakableSchema)} />}
<style>
  .faq-list {
    display: grid;
    gap: 10px;
    max-width: 880px;
    margin: 0 auto;
  }
  .faq-item {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    transition:
      border-color .3s ease,
      box-shadow .3s ease,
      transform .3s ease,
      background .3s ease;
  }
  .faq-item:hover {
    border-color: color-mix(in oklch, var(--gold) 40%, var(--line));
    box-shadow: 0 6px 16px -8px rgba(20, 37, 63, 0.12);
  }
  .faq-item[open] {
    border-color: color-mix(in oklch, var(--gold) 55%, var(--line));
    background: linear-gradient(180deg, #fff 0%, #fdf9f0 100%);
    box-shadow: 0 14px 36px -16px rgba(20, 37, 63, 0.18);
  }
  .faq-item summary {
    cursor: pointer;
    padding: 22px 26px;
    font-family: var(--serif);
    font-size: clamp(1.05rem, 1.6vw, 1.18rem);
    font-weight: 500;
    color: var(--ink);
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    line-height: 1.4;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::marker { display: none; }
  .faq-q { flex: 1; }

  /* Round chevron container — fills with gold on open, hover lift */
  .faq-icon {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--paper-2);
    border: 1px solid var(--line);
    color: var(--ink-soft);
    transition:
      background .35s ease,
      border-color .35s ease,
      color .35s ease,
      transform .35s ease;
  }
  .faq-item:hover .faq-icon {
    background: #fff;
    border-color: color-mix(in oklch, var(--gold) 55%, var(--line));
    color: var(--gold);
  }
  .faq-item[open] .faq-icon {
    background: var(--gold);
    border-color: var(--gold);
    color: #fff;
  }
  .faq-chev {
    transition: transform var(--t-fast);
  }
  .faq-item[open] .faq-chev { transform: rotate(180deg); }

  .faq-a {
    padding: 0 26px 24px;
    color: var(--ink-soft);
    line-height: 1.7;
    font-size: 0.98rem;
  }
  .faq-a p { margin: 0; }

  @media (prefers-reduced-motion: reduce) {
    .faq-chev, .faq-icon, .faq-item { transition: none; }
  }
  @media (max-width: 600px) {
    .faq-item summary { padding: 18px 20px; gap: 12px; }
    .faq-icon { width: 32px; height: 32px; }
    .faq-a { padding: 0 20px 20px; }
  }
</style>
