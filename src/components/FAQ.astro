---
interface QA { q: string; a: string; }
interface Props {
  items: QA[];
  title?: string;
  /**
   * Emit `FAQPage` JSON-LD. After Google's March 2026 structured-data update,
   * FAQ rich results are restricted to pages where Q&A is the primary content.
   * On service / sector / blog pages where the FAQ is supplementary, the
   * markup wins no rich result and dilutes our schema graph — so we ship the
   * visible accordion without it. Set `withSchema={true}` only on a future
   * dedicated `/faq` page (or any page where the FAQ truly is the main body).
   */
  withSchema?: boolean;
}
const { items, title = 'Questions fréquentes', withSchema = false } = Astro.props;

const faqPageSchema = withSchema ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'fr-MA',
  mainEntity: items.map(i => ({
    '@type': 'Question',
    name: i.q,
    acceptedAnswer: { '@type': 'Answer', text: i.a, inLanguage: 'fr-MA' },
  })),
} : null;

/** Speakable hints for AI Mode / voice — emitted even when FAQPage schema is off. */
const faqSpeakableSchema = items.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'WebPageElement',
  name: title,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.faq-item summary', '.faq-a'],
  },
} : null;
---
<section class="faq-section" aria-labelledby="faq-title">
  <div class="container">
    <h2 id="faq-title" class="reveal">{title}</h2>
    <div class="faq-list">
      {items.map((it, i) => (
        <details class="faq-item reveal" style={`transition-delay:${i * 60}ms`}>
          <summary>
            <span class="faq-q">{it.q}</span>
            <svg class="faq-chev" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </summary>
          <div class="faq-a"><p>{it.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>
{faqPageSchema && <script type="application/ld+json" set:html={JSON.stringify(faqPageSchema)} />}
{faqSpeakableSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSpeakableSchema)} />}
<style>
  .faq-section h2 { margin-bottom: 28px; }
  .faq-list { display: grid; gap: 12px; max-width: 820px; }
  .faq-item {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
  }
  .faq-item[open] { border-color: var(--gold); box-shadow: var(--shadow-1); }
  .faq-item summary {
    cursor: pointer;
    padding: 18px 22px;
    font-family: var(--serif);
    font-size: 1.08rem;
    font-weight: 500;
    color: var(--ink);
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::marker { display: none; }
  .faq-q { flex: 1; }
  .faq-chev {
    color: var(--gold);
    flex-shrink: 0;
    transition: transform var(--t-fast);
  }
  .faq-item[open] .faq-chev { transform: rotate(180deg); }
  .faq-a { padding: 0 22px 18px; color: var(--ink-soft); line-height: 1.65; }
  @media (prefers-reduced-motion: reduce) {
    .faq-chev { transition: none; }
  }
</style>
