---
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (p: string) => path === p || (p !== '/' && path.startsWith(p));
---
<header class="site-header" data-header>
  <a href="#main" class="skip-link">Aller au contenu principal</a>
  <div class="container header-row">
    <a href="/" class="brand" aria-label="Accueil — Consulting Maghreb Expertise">
      <picture>
        <source srcset="/images/cme-logo-96.webp" type="image/webp" />
        <img src="/images/cme-logo-96.png" alt="" class="brand-logo" width="48" height="48" decoding="async" />
      </picture>
      <span class="brand-name">Consulting Maghreb<br/>Expertise</span>
    </a>

    <button class="nav-toggle" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="primary-nav" data-nav-toggle>
      <span class="bar bar-1"></span>
      <span class="bar bar-2"></span>
      <span class="bar bar-3"></span>
    </button>

    <div class="nav-backdrop" data-nav-backdrop aria-hidden="true"></div>

    <nav id="primary-nav" class="primary-nav" aria-label="Menu principal" data-nav>
      <ul>
        <li><a href="/" class={isActive('/') ? 'active' : ''}>Accueil</a></li>
        <li class="has-sub" data-has-sub>
          <a
            href="/services"
            class={isActive('/services') ? 'active' : ''}
            aria-haspopup="true"
            aria-expanded="false"
            data-sub-toggle
          >Services <span aria-hidden="true">▾</span></a>
          <div class="sub">
            <div class="sub-grid">
              <div>
                <h4>Comptabilité</h4>
                <a href="/services/tenue-comptabilite">Tenue comptable</a>
                <a href="/services/supervision-comptable">Supervision</a>
                <a href="/services/gestion-financiere">Gestion financière</a>
                <a href="/services/audit">Audit</a>
                <a href="/services/comptabilite-pharmaciens">Pharmaciens</a>
              </div>
              <div>
                <h4>Fiscalité</h4>
                <a href="/services/conseil-fiscal">Conseil fiscal</a>
                <a href="/services/assistance-fiscale">Assistance fiscale</a>
                <a href="/services/controle-contentieux">Contrôle &amp; contentieux</a>
                <a href="/services/simpl-impots-dgi">Simpl Impôts DGI</a>
              </div>
              <div>
                <h4>Juridique</h4>
                <a href="/services/creation-entreprise">Création d'entreprise</a>
                <a href="/services/conseil-juridique">Conseil juridique</a>
                <a href="/services/travaux-juridiques">Travaux juridiques</a>
                <a href="/services/domiciliation">Domiciliation</a>
              </div>
              <div>
                <h4>Paie &amp; social</h4>
                <a href="/services/paie-grh">Paie &amp; GRH</a>
                <a href="/services/damancom-cnss">Damancom CNSS</a>
                <a href="/services/social-administratif">Social &amp; administratif</a>
                <a href="/services/business-plan">Business plan</a>
              </div>
            </div>
          </div>
        </li>
        <li><a href="/secteurs" class={isActive('/secteurs') ? 'active' : ''}>Secteurs</a></li>
        <li><a href="/zones" class={isActive('/zones') ? 'active' : ''}>Zones</a></li>
        <li><a href="/quartiers" class={isActive('/quartiers') ? 'active' : ''}>Quartiers</a></li>
        <li class="has-sub" data-has-sub>
          <a
            href="/outils"
            class={isActive('/outils') || isActive('/glossaire') || isActive('/comparatifs') || isActive('/documentation') ? 'active' : ''}
            aria-haspopup="true"
            aria-expanded="false"
            data-sub-toggle
          >Ressources <span aria-hidden="true">▾</span></a>
          <div class="sub sub-narrow">
            <div class="sub-grid sub-grid-2">
              <div>
                <h4>Outils gratuits</h4>
                <a href="/outils/simulateur-is">Simulateur IS 2026</a>
                <a href="/outils/simulateur-paie">Simulateur paie</a>
                <a href="/outils/simulateur-tva">Calcul TVA</a>
                <a href="/outils/simulateur-creation">Coût création société</a>
                <a href="/outils/simulateur-ir">Simulateur IR</a>
              </div>
              <div>
                <h4>Documentation</h4>
                <a href="/documentation">Ressources</a>
                <a href="/glossaire">Glossaire comptable</a>
                <a href="/comparatifs">Comparatifs</a>
                <a href="/blog">Le Journal</a>
                <a href="/avis-clients">Avis clients</a>
                <a href="/expat">Expatriés &amp; SCI</a>
              </div>
            </div>
          </div>
        </li>
        <li><a href="/cabinet" class={isActive('/cabinet') ? 'active' : ''}>Cabinet</a></li>
        <li><a href="/tarifs" class={isActive('/tarifs') ? 'active' : ''}>Tarifs</a></li>
      </ul>
      <a href="/contact" class="btn btn-gold nav-cta">Devis gratuit</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(254, 252, 246, 0.85);
    backdrop-filter: saturate(160%) blur(14px);
    -webkit-backdrop-filter: saturate(160%) blur(14px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
  }
  .site-header.scrolled {
    border-bottom-color: var(--line);
    box-shadow: var(--shadow-1);
  }
  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-block: 14px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--ink);
  }
  .brand-logo {
    width: 48px; height: 48px;
    object-fit: contain;
    transition: transform .35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .brand:hover .brand-logo {
    transform: rotate(-6deg) scale(1.06);
  }
  .brand-name {
    font-family: var(--serif);
    font-size: 13px;
    line-height: 1.15;
    color: var(--ink);
    font-weight: 500;
  }
  .primary-nav { display: flex; align-items: center; gap: 18px; }
  .primary-nav > ul {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    gap: 18px;
  }
  .primary-nav a {
    text-decoration: none;
    color: var(--ink);
    font-size: 14.5px;
    font-weight: 500;
    padding: 8px 2px;
    position: relative;
    white-space: nowrap;
  }
  .primary-nav > ul > li > a.active::after,
  .primary-nav > ul > li > a:hover::after {
    content: "";
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gold);
    border-radius: 2px;
  }
  .has-sub { position: relative; }
  .sub {
    position: absolute;
    top: 100%;
    left: -20px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 24px;
    width: 720px;
    max-width: calc(100vw - 40px);
    box-shadow: var(--shadow-2);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity var(--t-fast), transform var(--t-fast), visibility var(--t-fast);
  }
  .has-sub:hover .sub,
  .has-sub:focus-within .sub,
  .has-sub.sub-open .sub {
    opacity: 1;
    visibility: visible;
    transform: none;
  }
  .has-sub > a[data-sub-toggle] > span { transition: transform var(--t-fast); }
  .has-sub.sub-open > a[data-sub-toggle] > span { transform: rotate(180deg); }
  .sub-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .sub.sub-narrow { width: 440px; }
  .sub-grid.sub-grid-2 { grid-template-columns: 1fr 1fr; }
  .sub-grid h4 {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .sub-grid a {
    display: flex;
    align-items: center;
    padding: 8px 12px;
    font-size: 14px;
    border-radius: 8px;
    margin-inline: -10px;
    color: var(--ink);
    position: relative;
    transition: color .2s ease, background .25s ease, padding-left .3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .sub-grid a::before {
    content: "";
    width: 0;
    height: 1.5px;
    background: var(--gold);
    margin-right: 0;
    border-radius: 2px;
    transition: width .3s cubic-bezier(0.4, 0, 0.2, 1), margin-right .3s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }
  .sub-grid a:hover {
    color: var(--gold);
    background: linear-gradient(90deg, rgba(200, 168, 90, 0.08) 0%, transparent 100%);
  }
  .sub-grid a:hover::before {
    width: 14px;
    margin-right: 10px;
  }
  .nav-cta { padding: 9px 16px; font-size: 13.5px; white-space: nowrap; flex-shrink: 0; }

  /* Hamburger button */
  .nav-toggle {
    display: none;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 12px;
    width: 44px; height: 44px;
    position: relative;
    cursor: pointer;
    z-index: 102;
    transition: background .25s ease, border-color .25s ease;
    padding: 0;
  }
  .nav-toggle:hover { background: var(--paper-2); border-color: var(--ink); }
  .nav-toggle .bar {
    position: absolute;
    left: 50%; top: 50%;
    width: 18px; height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transform: translate(-50%, -50%);
    transition: transform .35s cubic-bezier(0.4, 0, 0.2, 1), opacity .25s ease;
  }
  .nav-toggle .bar-1 { transform: translate(-50%, calc(-50% - 6px)); }
  .nav-toggle .bar-3 { transform: translate(-50%, calc(-50% + 6px)); }
  .nav-toggle[aria-expanded="true"] .bar-1 { transform: translate(-50%, -50%) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] .bar-2 { opacity: 0; transform: translate(-50%, -50%) scaleX(0); }
  .nav-toggle[aria-expanded="true"] .bar-3 { transform: translate(-50%, -50%) rotate(-45deg); }

  /* Backdrop overlay */
  .nav-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 20, 30, 0.45);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    z-index: 99;
    transition: opacity .35s ease;
  }
  .nav-backdrop.show {
    display: block;
    opacity: 1;
  }

  /* Tablet & below: hamburger menu */
  @media (max-width: 1180px) {
    .nav-toggle { display: block; }

    .primary-nav {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(420px, 92vw);
      background: linear-gradient(180deg, var(--paper) 0%, #f7f1e3 100%);
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 88px 28px 28px;
      border-left: 1px solid var(--line);
      overflow-y: auto;
      overflow-x: hidden;
      transform: translateX(100%);
      transition: transform .45s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: -24px 0 60px -20px rgba(15, 20, 30, 0.25);
      z-index: 101;
      overscroll-behavior: contain;
    }
    .primary-nav.open { transform: translateX(0); }
    .primary-nav > ul {
      flex-direction: column;
      gap: 0;
      padding: 0;
    }
    .primary-nav > ul > li {
      border-bottom: 1px solid var(--line);
    }
    .primary-nav > ul > li:last-child {
      border-bottom: none;
    }
    .primary-nav > ul > li > a {
      padding: 16px 0;
      font-size: 16px;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .primary-nav > ul > li > a.active::after,
    .primary-nav > ul > li > a:hover::after { display: none; }
    .primary-nav > ul > li > a.active { color: var(--gold); }

    .has-sub > a span { transition: transform .3s ease; }
    .sub {
      position: static;
      width: auto;
      max-width: none;
      box-shadow: none;
      opacity: 1;
      visibility: visible;
      transform: none;
      padding: 0 0 12px 12px;
      border: none;
      background: transparent;
      border-radius: 0;
    }
    .sub-grid { grid-template-columns: 1fr; gap: 12px; }
    .sub.sub-narrow { width: auto; }
    .sub-grid.sub-grid-2 { grid-template-columns: 1fr; }
    .sub-grid h4 {
      margin-top: 4px;
      font-size: 10px;
    }
    .sub-grid > div + div {
      margin-top: 8px;
      padding-top: 10px;
      border-top: 1px dashed var(--line);
    }
    .sub-grid a {
      padding: 10px 12px;
      margin-inline: -8px;
      font-size: 14px;
    }
    .nav-cta {
      margin-top: 24px;
      justify-content: center;
      padding: 14px 22px;
      font-size: 15px;
      width: 100%;
    }
  }

  /* Small tablet: tighter brand */
  @media (max-width: 720px) {
    .header-row { gap: 12px; padding-block: 12px; }
    .brand-logo { width: 40px; height: 40px; }
    .brand-name { font-size: 12px; }
    .primary-nav {
      width: 100vw;
      max-width: 100vw;
      padding: 80px 24px 24px;
      border-left: none;
    }
  }

  /* Phone: hide brand text, keep logo only */
  @media (max-width: 480px) {
    .brand-name { display: none; }
    .brand { gap: 0; }
    .container.header-row { padding-inline: 16px; }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('[data-header]');
  const onScroll = () => {
    if (window.scrollY > 6) header?.classList.add('scrolled');
    else header?.classList.remove('scrolled');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const toggle = document.querySelector<HTMLElement>('[data-nav-toggle]');
  const nav = document.querySelector<HTMLElement>('[data-nav]');
  const backdrop = document.querySelector<HTMLElement>('[data-nav-backdrop]');

  const setOpen = (open: boolean) => {
    if (!nav || !toggle || !backdrop) return;
    nav.classList.toggle('open', open);
    backdrop.classList.toggle('show', open);
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
    document.body.style.overflow = open ? 'hidden' : '';
  };

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.contains('open');
    setOpen(!isOpen);
  });

  backdrop?.addEventListener('click', () => setOpen(false));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && nav?.classList.contains('open')) setOpen(false);
  });

  nav?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    setOpen(false);
  }));

  // Reset menu state on resize back to desktop
  const mq = window.matchMedia('(min-width: 1181px)');
  mq.addEventListener('change', (e) => {
    if (e.matches) setOpen(false);
  });

  // Desktop sub-nav: explicit click + aria-expanded toggle. Hover and
  // :focus-within still open the panel (the existing CSS handles those),
  // but keyboard users on touch devices and assistive-tech users now get
  // a real, intent-driven control. Tapping the toggle on touch screens
  // reveals the sub-nav without forcing the parent link to navigate.
  const desktopMq = window.matchMedia('(min-width: 1181px)');
  const subToggles = document.querySelectorAll<HTMLAnchorElement>('[data-sub-toggle]');
  const closeOtherSubs = (except?: HTMLLIElement) => {
    document.querySelectorAll<HTMLLIElement>('[data-has-sub]').forEach((li) => {
      if (li === except) return;
      li.classList.remove('sub-open');
      const t = li.querySelector<HTMLAnchorElement>('[data-sub-toggle]');
      t?.setAttribute('aria-expanded', 'false');
    });
  };
  subToggles.forEach((toggle) => {
    toggle.addEventListener('click', (e) => {
      // Mobile drawer: parent link should navigate normally; sub-nav opens
      // via the `nav.open` state, not via click handler here.
      if (!desktopMq.matches) return;
      const li = toggle.closest<HTMLLIElement>('[data-has-sub]');
      if (!li) return;
      // First click reveals the sub-panel; second click (already open)
      // falls through and navigates to the parent route.
      const alreadyOpen = li.classList.contains('sub-open');
      if (alreadyOpen) return;
      e.preventDefault();
      closeOtherSubs(li);
      li.classList.add('sub-open');
      toggle.setAttribute('aria-expanded', 'true');
      // Move keyboard focus into the panel for screen-reader users.
      const firstLink = li.querySelector<HTMLAnchorElement>('.sub a');
      firstLink?.focus({ preventScroll: true });
    });
  });
  // Close sub-nav on outside click + Escape.
  document.addEventListener('click', (e) => {
    const inSub = (e.target as Element)?.closest('[data-has-sub]');
    if (!inSub) closeOtherSubs();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const open = document.querySelector<HTMLLIElement>('[data-has-sub].sub-open');
      if (open) {
        closeOtherSubs();
        open.querySelector<HTMLAnchorElement>('[data-sub-toggle]')?.focus();
      }
    }
  });
</script>
