---
import Icon from './Icon.astro';
interface Props {
  href: string;
  title: string;
  description: string;
  icon?: string;
  tag?: string;
}
const { href, title, description, icon, tag } = Astro.props;
---
<a href={href} class="svc-card card tilt reveal">
  <span class="card-shine" aria-hidden="true"></span>
  {icon && (
    <div class="svc-icon" aria-hidden="true">
      <Icon name={icon as any} size={22} stroke={1.6} />
    </div>
  )}
  {tag && <span class="tag">{tag}</span>}
  <h3>{title}</h3>
  <p>{description}</p>
  <span class="arrow" aria-hidden="true">
    <Icon name="arrow-right" size={20} stroke={1.8} />
  </span>
</a>
<style>
  .svc-card {
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .card-shine {
    position: absolute;
    inset: 0;
    background: radial-gradient(380px circle at var(--mx, 50%) var(--my, -20%), color-mix(in srgb, var(--gold) 12%, transparent), transparent 50%);
    opacity: 0;
    transition: opacity .35s ease;
    pointer-events: none;
    z-index: 0;
  }
  .svc-card:hover .card-shine { opacity: 1; }
  .svc-card > * { position: relative; z-index: 1; }
  .svc-card h3 {
    font-size: 1.2rem;
    margin: 6px 0 4px;
  }
  .svc-card p {
    color: var(--ink-soft);
    font-size: 14.5px;
    line-height: 1.55;
    margin: 0;
  }
  .svc-icon {
    width: 48px; height: 48px;
    background: linear-gradient(135deg, var(--paper-2) 0%, #fff 100%);
    border: 1px solid var(--line);
    border-radius: 14px;
    display: grid; place-items: center;
    color: var(--ink);
    margin-bottom: 6px;
    transition: background .35s ease, transform .35s cubic-bezier(0.34, 1.56, 0.64, 1), color .35s ease, border-color .35s ease, box-shadow .35s ease;
  }
  .svc-card:hover .svc-icon {
    background: linear-gradient(135deg, var(--gold) 0%, #d4a857 100%);
    color: #fff;
    border-color: transparent;
    transform: translateY(-2px) rotate(-4deg) scale(1.05);
    box-shadow: 0 8px 24px -8px rgba(196, 154, 70, 0.55);
  }
  .arrow {
    margin-top: auto;
    color: var(--gold);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: transform .3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .svc-card:hover .arrow { transform: translateX(6px); }
  .tag { width: fit-content; }
</style>
