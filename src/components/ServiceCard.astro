---
import Icon from './Icon.astro';
interface Props {
  href: string;
  title: string;
  description: string;
  icon?: string;
  tag?: string;
}
const { href, title, description, icon, tag } = Astro.props;
---
<a href={href} class="svc-card card tilt reveal">
  <span class="card-shine" aria-hidden="true"></span>
  <span class="card-corner" aria-hidden="true"></span>
  {icon && (
    <div class="svc-icon" aria-hidden="true">
      <Icon name={icon as any} size={22} stroke={1.6} />
    </div>
  )}
  {tag && <span class="tag">{tag}</span>}
  <h3>{title}</h3>
  <p>{description}</p>
  <span class="svc-cta">
    <span>En savoir plus</span>
    <Icon name="arrow-right" size={16} stroke={2} />
  </span>
</a>
<style>
  .svc-card {
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    min-height: 220px;
  }
  .card-shine {
    position: absolute;
    inset: 0;
    background: radial-gradient(380px circle at var(--mx, 50%) var(--my, -20%), color-mix(in srgb, var(--gold) 14%, transparent), transparent 50%);
    opacity: 0;
    transition: opacity .35s ease;
    pointer-events: none;
    z-index: 0;
  }
  .svc-card:hover .card-shine { opacity: 1; }
  /* Decorative top-right corner triangle that pops on hover. */
  .card-corner {
    position: absolute;
    top: 0;
    right: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 56px 56px 0;
    border-color: transparent var(--paper-2) transparent transparent;
    opacity: 0.7;
    transition: border-color .35s ease, opacity .35s ease, transform .35s ease;
    pointer-events: none;
    z-index: 0;
  }
  .svc-card:hover .card-corner {
    border-color: transparent color-mix(in oklch, var(--gold) 25%, var(--paper-2)) transparent transparent;
    transform: scale(1.05);
    opacity: 1;
  }
  .svc-card > *:not(.card-shine):not(.card-corner) { position: relative; z-index: 1; }

  .svc-card h3 {
    font-size: 1.22rem;
    margin: 6px 0 4px;
    transition: color .25s ease;
  }
  .svc-card:hover h3 { color: var(--accent-2); }

  .svc-card p {
    color: var(--ink-soft);
    font-size: 14.5px;
    line-height: 1.6;
    margin: 0;
  }
  .svc-icon {
    width: 52px; height: 52px;
    background: linear-gradient(135deg, var(--paper-2) 0%, #fff 100%);
    border: 1px solid var(--line);
    border-radius: 14px;
    display: grid; place-items: center;
    color: var(--ink);
    margin-bottom: 6px;
    transition: background .35s ease, transform .35s cubic-bezier(0.34, 1.56, 0.64, 1), color .35s ease, border-color .35s ease, box-shadow .35s ease;
  }
  .svc-card:hover .svc-icon {
    background: linear-gradient(135deg, var(--gold) 0%, #d4a857 100%);
    color: #fff;
    border-color: transparent;
    transform: translateY(-2px) rotate(-4deg) scale(1.05);
    box-shadow: 0 10px 28px -10px rgba(196, 154, 70, 0.6);
  }

  /* CTA link reveal — fades in fully on hover, sits at bottom */
  .svc-cta {
    margin-top: auto;
    padding-top: 14px;
    color: var(--gold);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13.5px;
    font-weight: 600;
    letter-spacing: 0.01em;
    opacity: 0.75;
    transform: translateX(0);
    transition: opacity .3s ease, transform .3s cubic-bezier(0.4, 0, 0.2, 1), gap .3s ease;
  }
  .svc-card:hover .svc-cta {
    opacity: 1;
    gap: 12px;
  }
  .svc-cta :global(.icon) { transition: transform .3s ease; }
  .svc-card:hover .svc-cta :global(.icon) { transform: translateX(4px); }

  .tag { width: fit-content; }
</style>
