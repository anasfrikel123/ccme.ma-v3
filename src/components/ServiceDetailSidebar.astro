---
import type { ServiceRelated } from '~/data/services-detail';
import { cabinet } from '~/data/cabinet';

interface Props {
  contactHref?: string;
  related?: ServiceRelated[];
}

const { contactHref = '/contact', related = [] } = Astro.props;
---
<aside class="detail-aside reveal-right">
  <div class="detail-aside-card">
    <span class="eyebrow">Devis gratuit</span>
    <h3>Besoin de cette prestation ?</h3>
    <p>Parlons de votre situation lors d'un premier échange gratuit. Réponse sous 24 h ouvrées.</p>
    <a href={contactHref} class="btn btn-gold">Demander un devis <span class="arrow" aria-hidden="true">→</span></a>
    <div class="aside-contact">
      <a href={cabinet.phone.tel}>
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.5 2.1L8 11.5a16 16 0 0 0 6 6l1-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2Z" /></svg>
        {cabinet.phone.display}
      </a>
      <a href={`mailto:${cabinet.email}`}>
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2" /><path d="m4 7 8 6 8-6" /></svg>
        {cabinet.email}
      </a>
    </div>
    {related.length > 0 && (
      <ul class="related">
        <li class="rl-label">Services liés</li>
        {related.map((r) => (
          <li>
            <a href={r.href}>{r.label}<span aria-hidden="true">→</span></a>
          </li>
        ))}
      </ul>
    )}
  </div>
</aside>

<style>
  .related li { list-style: none; }
</style>
