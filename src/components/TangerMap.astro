---
/**
 * Schematic interactive map of Tanger zones / quartiers.
 *
 * Not a real geo-map (no mapbox/leaflet) — a hand-positioned SVG illustration
 * good enough to anchor each zone in space and let users click their way in.
 * Coordinates are tuned visually, not from real lat/lng. The intent is to
 * give a cognitive shortcut for users who think geographically ("where's
 * TFZ vs TAC vs Tanger Med?") without paying the perf cost of an iframe map.
 *
 * Two modes via the `kind` prop:
 *   - "zones"     — the 5 economic zones we cover.
 *   - "quartiers" — the 6 residential quartiers (denser, smaller dots).
 *
 * Each pin is keyboard-navigable and announces its label via aria-label.
 */
interface Pin {
  id: string;
  label: string;
  href: string;
  /** % of the bounding viewBox (0-100). */
  x: number;
  y: number;
  /** Optional one-liner for the tooltip. */
  desc?: string;
  /** "primary" pins get a slightly bigger dot (Tanger Med, TFZ). */
  primary?: boolean;
}

interface Props {
  kind: 'zones' | 'quartiers';
}
const { kind } = Astro.props;

const ZONE_PINS: Pin[] = [
  { id: 'tanger-med', label: 'Tanger Med', href: '/zones/tanger-med', x: 86, y: 18, desc: 'Port + zones franches industrielles', primary: true },
  { id: 'tanger-tech', label: 'Tanger Tech', href: '/zones/tanger-tech', x: 70, y: 30, desc: 'Pôle technologique (R&D, logiciel)' },
  { id: 'tanger-free-zone', label: 'Tanger Free Zone (TFZ)', href: '/zones/tanger-free-zone', x: 60, y: 64, desc: 'Zone franche aéroportuaire', primary: true },
  { id: 'tanger-automotive-city', label: 'Tanger Automotive City', href: '/zones/tanger-automotive-city', x: 40, y: 78, desc: 'Cluster automobile + tertiaire' },
  { id: 'centre-ville', label: 'Centre-ville', href: '/zones/centre-ville', x: 26, y: 38, desc: 'Cabinet, banques, sièges sociaux' },
];

const QUARTIER_PINS: Pin[] = [
  { id: 'marshan', label: 'Marshan', href: '/quartiers/marshan', x: 22, y: 26, desc: 'Résidentiel haut de gamme' },
  { id: 'iberia', label: 'Iberia', href: '/quartiers/iberia', x: 28, y: 38, desc: 'Centre historique' },
  { id: 'california', label: 'California', href: '/quartiers/california', x: 36, y: 30, desc: 'Résidentiel + commerces' },
  { id: 'malabata', label: 'Malabata', href: '/quartiers/malabata', x: 60, y: 22, desc: 'Front de mer, hôtels' },
  { id: 'beni-makada', label: 'Beni Makada', href: '/quartiers/beni-makada', x: 32, y: 64, desc: 'Sud Tanger, secteur populaire' },
  { id: 'boukhalef', label: 'Boukhalef', href: '/quartiers/boukhalef', x: 56, y: 70, desc: 'Aéroport / TFZ accessible' },
];

const pins = kind === 'zones' ? ZONE_PINS : QUARTIER_PINS;
const headline = kind === 'zones' ? 'Carte des zones économiques' : 'Carte des quartiers';
const intro = kind === 'zones'
  ? 'Cliquez sur une zone pour ouvrir sa fiche. Le cabinet intervient dans tout le périmètre de la wilaya de Tanger-Tétouan-Al Hoceïma.'
  : 'Cliquez sur un quartier pour découvrir notre couverture commerciale et résidentielle.';
---
<div class="map-card reveal" aria-labelledby="map-title">
  <div class="map-head">
    <p class="eyebrow eyebrow-gold">Carte interactive</p>
    <h2 id="map-title">{headline}</h2>
    <p class="map-intro">{intro}</p>
  </div>

  <div class="map-frame" role="region" aria-label="Carte schématique de Tanger">
    <svg
      class="map-svg"
      viewBox="0 0 100 100"
      preserveAspectRatio="xMidYMid meet"
      aria-hidden="true"
    >
      <!-- Sea / land driven by CSS vars so dark mode can re-theme without
           swapping the SVG markup. -->
      <rect class="map-sea" x="0" y="0" width="100" height="100" />
      <path
        class="map-land"
        d="M 0,40 C 8,32 18,30 26,32 C 38,34 48,30 56,28 C 65,26 72,22 80,18 C 86,16 92,14 100,12 L 100,100 L 0,100 Z"
      />
      <path
        class="map-coast"
        d="M 0,40 C 8,32 18,30 26,32 C 38,34 48,30 56,28 C 65,26 72,22 80,18 C 86,16 92,14 100,12"
      />
      <path
        class="map-highway"
        d="M 28,40 L 42,55 L 58,70 L 72,72"
      />
      <text class="map-label" x="62" y="9" font-size="3" font-family="serif" font-style="italic">Détroit de Gibraltar</text>
    </svg>

    <ul class="map-pins">
      {pins.map(p => (
        <li
          class={`map-pin ${p.primary ? 'is-primary' : ''}`}
          style={`--x: ${p.x}%; --y: ${p.y}%;`}
        >
          <a
            href={p.href}
            aria-label={`${p.label}${p.desc ? ' — ' + p.desc : ''}`}
            data-pin-id={p.id}
          >
            <span class="map-pin-dot" aria-hidden="true"></span>
            <span class="map-pin-label">{p.label}</span>
            {p.desc && <span class="map-pin-desc">{p.desc}</span>}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="map-legend">
    <span class="map-legend-item"><span class="map-legend-dot is-primary" aria-hidden="true"></span> Zone majeure</span>
    <span class="map-legend-item"><span class="map-legend-dot" aria-hidden="true"></span> Zone secondaire</span>
    <span class="map-legend-item map-legend-note">Schéma indicatif, non géolocalisé</span>
  </div>
</div>

<style>
  .map-card {
    background: linear-gradient(135deg, #fff 0%, var(--paper-2) 100%);
    border: 1px solid var(--line);
    border-radius: var(--r-xl);
    padding: clamp(24px, 3vw, 36px);
    margin-bottom: clamp(28px, 4vw, 44px);
    overflow: hidden;
  }

  .map-head { margin-bottom: 22px; }
  .map-head h2 {
    margin: 6px 0 8px;
    font-size: clamp(1.4rem, 2.4vw, 1.7rem);
    line-height: 1.2;
  }
  .map-intro {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0;
    max-width: 620px;
  }

  .map-frame {
    position: relative;
    width: 100%;
    border-radius: var(--r-lg);
    overflow: hidden;
    border: 1px solid color-mix(in oklch, var(--gold) 18%, var(--line));
    aspect-ratio: 16 / 9;
    background: var(--map-sea, #cad6df);
  }
  .map-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .map-sea { fill: var(--map-sea, #cad6df); }
  .map-land { fill: var(--map-land, #ebe1d2); }
  .map-coast { stroke: var(--gold); stroke-width: 0.4; stroke-opacity: 0.5; fill: none; }
  .map-highway { stroke: var(--map-highway, #9aa1a8); stroke-width: 0.35; stroke-dasharray: 1.4 1.2; fill: none; }
  .map-label { fill: var(--map-label, #7c8b95); }
  :root[data-theme="dark"] .map-frame {
    --map-sea: #14110b;
    --map-land: #211c12;
    --map-highway: color-mix(in oklch, var(--gold) 25%, var(--paper));
    --map-label: var(--ink-soft);
  }
  .map-pins {
    position: absolute;
    inset: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .map-pin {
    position: absolute;
    left: var(--x);
    top: var(--y);
    transform: translate(-50%, -50%);
  }
  .map-pin a {
    display: block;
    text-decoration: none;
    color: var(--ink);
    position: relative;
    padding: 8px 14px;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    border: 1px solid color-mix(in oklch, var(--gold) 30%, var(--line));
    border-radius: 999px;
    font-size: 12.5px;
    font-weight: 600;
    line-height: 1.2;
    box-shadow: 0 6px 16px -8px rgba(20, 37, 63, 0.28);
    transition: all .25s ease;
    white-space: nowrap;
  }
  .map-pin a:hover, .map-pin a:focus-visible {
    transform: translateY(-2px);
    background: var(--gold);
    color: #2a1f04;
    border-color: var(--gold);
    box-shadow: 0 12px 24px -8px rgba(196, 154, 70, 0.55);
    z-index: 10;
  }
  .map-pin-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--gold);
    margin-right: 8px;
    vertical-align: middle;
    box-shadow: 0 0 0 3px rgba(196, 154, 70, 0.18);
  }
  .map-pin.is-primary .map-pin-dot {
    width: 11px;
    height: 11px;
    box-shadow: 0 0 0 4px rgba(196, 154, 70, 0.22);
    animation: map-pulse 2.4s ease-in-out infinite;
  }
  @keyframes map-pulse {
    0%, 100% { box-shadow: 0 0 0 4px rgba(196, 154, 70, 0.22); }
    50% { box-shadow: 0 0 0 8px rgba(196, 154, 70, 0.06); }
  }
  .map-pin-desc {
    display: block;
    font-size: 11px;
    font-weight: 500;
    color: var(--muted);
    margin-top: 2px;
    line-height: 1.3;
  }
  .map-pin a:hover .map-pin-desc, .map-pin a:focus-visible .map-pin-desc {
    color: rgba(42, 31, 4, 0.72);
  }
  .map-pin a:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }

  .map-legend {
    margin-top: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    font-size: 12.5px;
    color: var(--muted);
  }
  .map-legend-item { display: inline-flex; align-items: center; gap: 6px; }
  .map-legend-dot {
    width: 8px; height: 8px;
    border-radius: 999px;
    background: var(--gold);
    box-shadow: 0 0 0 3px rgba(196, 154, 70, 0.18);
  }
  .map-legend-dot.is-primary {
    width: 11px; height: 11px;
    box-shadow: 0 0 0 4px rgba(196, 154, 70, 0.22);
  }
  .map-legend-note { margin-left: auto; font-style: italic; }

  @media (max-width: 720px) {
    .map-frame { aspect-ratio: 4 / 5; }
    .map-pin a { padding: 6px 10px; font-size: 11.5px; }
    .map-pin-desc { display: none; }
    .map-legend-note { margin-left: 0; flex-basis: 100%; }
  }
</style>
