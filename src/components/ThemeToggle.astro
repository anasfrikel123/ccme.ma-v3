---
/**
 * Light/dark theme toggle. The actual `data-theme` attribute is set
 * by the inline FOUC-prevention script in Base.astro before this
 * component renders — that script reads `localStorage.theme` (or the
 * `prefers-color-scheme` media query) and applies it to <html>
 * synchronously to avoid a flash of incorrect theme.
 *
 * This button only flips the current state and persists it. The
 * dispatched `ccme:theme-changed` event lets other components react
 * (currently unused, kept as a hook).
 */
---
<button
  type="button"
  class="theme-toggle"
  data-theme-toggle
  aria-label="Basculer thème clair / sombre"
  title="Thème clair / sombre"
>
  <svg class="theme-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <line x1="12" y1="2" x2="12" y2="5"></line>
    <line x1="12" y1="19" x2="12" y2="22"></line>
    <line x1="4.93" y1="4.93" x2="7.05" y2="7.05"></line>
    <line x1="16.95" y1="16.95" x2="19.07" y2="19.07"></line>
    <line x1="2" y1="12" x2="5" y2="12"></line>
    <line x1="19" y1="12" x2="22" y2="12"></line>
    <line x1="4.93" y1="19.07" x2="7.05" y2="16.95"></line>
    <line x1="16.95" y1="7.05" x2="19.07" y2="4.93"></line>
  </svg>
  <svg class="theme-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--ink-soft);
    cursor: pointer;
    transition: all .25s ease;
    font-family: inherit;
    flex-shrink: 0;
  }
  .theme-toggle:hover {
    border-color: var(--gold);
    color: var(--ink);
    background: color-mix(in oklch, var(--gold) 8%, transparent);
  }
  .theme-toggle:focus-visible { outline: 2px solid var(--gold); outline-offset: 3px; }

  .theme-sun, .theme-moon {
    grid-column: 1;
    grid-row: 1;
    transition: opacity .25s ease, transform .35s ease;
  }
  /* Default (light): show moon (action: switch to dark) */
  .theme-sun { opacity: 0; transform: rotate(-90deg) scale(0.5); }
  .theme-moon { opacity: 1; transform: rotate(0) scale(1); }
  /* Dark mode: show sun (action: switch back to light) */
  :root[data-theme="dark"] .theme-sun { opacity: 1; transform: rotate(0) scale(1); }
  :root[data-theme="dark"] .theme-moon { opacity: 0; transform: rotate(90deg) scale(0.5); }
</style>

<script>
  function getCurrent(): 'light' | 'dark' {
    return document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
  }
  function apply(theme: 'light' | 'dark') {
    document.documentElement.setAttribute('data-theme', theme);
    try { localStorage.setItem('ccme:theme', theme); } catch { /* private mode */ }
    window.dispatchEvent(new CustomEvent('ccme:theme-changed', { detail: theme }));
  }

  document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach(btn => {
    btn.addEventListener('click', () => {
      apply(getCurrent() === 'dark' ? 'light' : 'dark');
    });
  });
</script>
