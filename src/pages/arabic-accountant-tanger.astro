---
import Page from '~/layouts/Page.astro';
import FAQ from '~/components/FAQ.astro';

const faq = [
  { q: "هل تتعاملون مع المستثمرين الأجانب والعملاء الناطقين بالعربية؟", a: "نعم، وهذا أحد تخصّصاتنا. نعمل يوميًا مع مستثمرين من المغرب والخليج وأوروبا ممن ينشئون أو يديرون شركات في طنجة. نتكفّل بالمحاسبة والالتزامات الضريبية المحلية بالكامل وفق القانون المغربي، ونوافيكم بتقارير واضحة بالعربية أو الفرنسية. لن تواجهوا الإدارة المغربية وحدكم أو بلغة لا تتقنونها." },
  { q: "ما هو الخبير المحاسب المعتمد (OEC)، ولماذا يهمّ ذلك؟", a: "في المغرب، لا يحقّ سوى لمكتب مُقيَّد في هيئة الخبراء المحاسبين (Ordre des Experts-Comptables) حملُ لقب خبير محاسب، والمصادقة على القوائم المالية، وحيازة تأمين المسؤولية المهنية. كثير من «مكاتب المحاسبة» في طنجة غير معتمدة: يمكنها مسك الدفاتر الأساسية لكن لا يمكنها المصادقة على الحسابات أمام بنك أو مستثمر، ولا تتحمّل المسؤولية عند الخطأ. مكتب CCME معتمد لدى الهيئة، وهذا هو الفرق بين ماسك دفاتر وشريك مسؤول حقيقي." },
  { q: "هل يمكنكم تأسيس شركتي في منطقة حرّة بطنجة؟", a: "نعم. نرافق المستثمرين الأجانب في المنطقة الحرّة بطنجة (TFZ) ومدينة طنجة للسيارات (TAC) وطنجة تك وعلى منصة طنجة المتوسط. توفّر هذه المناطق نظامًا خاصًا لضريبة الشركات ومزايا جمركية، لكنها تحمل أيضًا التزامات خاصة، منها التصاريح أمام مكتب الصرف بشأن تدفّقات العملة الأجنبية. نتكفّل بالتأسيس وبالامتثال المستمر." },
  { q: "كيف تديرون إعادة تحويل الأرباح وقواعد الصرف؟", a: "كل عملية بالعملة الأجنبية مع الخارج تمرّ عبر مكتب الصرف. ندير توطين ملف الاستيراد والتصدير، ونبرّر التحويلات، ونهيكل إعادة تحويل أرباح الأسهم إلى الشريك الأجنبي بشكل سليم، بحيث تخرج أرباحكم من المغرب بصفة قانونية ودون تأخير." },
  { q: "هل يلزم أن أكون في المغرب للعمل معكم؟", a: "لا. يمكن إنجاز كل شيء عن بُعد وبشكل رقمي: ترسلون مستنداتكم عبر مساحة عمل مشتركة، فنعالجها ونوافيكم بقوائمكم المالية ولوحة متابعة شهرية. لدينا عملاء لم نلتقِ بهم شخصيًا قطّ وتسير محاسبتهم بسلاسة منذ سنوات. الاستشارة الأولى مجانية ويمكن إجراؤها عبر مكالمة فيديو." },
];

const SITE = 'https://ccme.ma';
const alternates = [
  { hreflang: 'fr', href: `${SITE}/expat` },
  { hreflang: 'en', href: `${SITE}/english-speaking-accountant-tanger` },
  { hreflang: 'es', href: `${SITE}/asesoria-contable-tanger-espanol` },
  { hreflang: 'ar', href: `${SITE}/arabic-accountant-tanger` },
  { hreflang: 'x-default', href: `${SITE}/english-speaking-accountant-tanger` },
];
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${SITE}/arabic-accountant-tanger#faq`,
  inLanguage: 'ar',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<Page
  lang="ar"
  dir="rtl"
  alternates={alternates}
  title="خبير محاسب معتمد في طنجة بالعربية — CCME"
  description="خبير محاسب معتمد (OEC) في طنجة للمستثمرين الأجانب: تأسيس الشركات، المناطق الحرّة، الضرائب، الأجور وتحويل الأرباح. استشارة أولى مجانية بدون التزام."
  eyebrow="للمستثمرين الأجانب"
  heading="خبير محاسب معتمد في طنجة، بالعربية"
  lede="مكتب خبراء محاسبين معتمد لدى هيئة الخبراء المحاسبين (OEC) في طنجة، يعمل مع المستثمرين الأجانب ورجال الأعمال الناطقين بالعربية: تأسيس الشركات، المناطق الحرّة، الجباية، الأجور، والتقارير، بعربية واضحة."
  breadcrumb={[{ label: 'الرئيسية', href: '/' }, { label: 'محاسب بالعربية' }]}
  keywords={["خبير محاسب طنجة","محاسب بالعربية المغرب","تأسيس شركة طنجة","محاسب للمستثمرين المغرب"]}
  schema={faqSchema}
>
  <section>
    <div class="container">
      <div class="prose" style="max-width: 900px; margin-inline: auto;">

        <h2>خبير محاسب حقيقي، لا مجرّد ماسك دفاتر</h2>
        <p>مكتب CCME (Consulting Maghreb Expertise) هو مكتب خبراء محاسبين مقرّه طنجة، مُقيَّد لدى <strong>هيئة الخبراء المحاسبين (OEC)</strong> ويخدم عملاءه منذ أكثر من 20 عامًا. نعمل مع مئات المقاولات في شمال المغرب، من بينها شركات كثيرة برأسمال أجنبي ومستثمرون دوليون يحتاجون إلى شريك محلي موثوق يمكنهم التحدّث معه بالعربية.</p>

        <h2>ماذا نقدّم للمستثمرين الأجانب</h2>
        <ul>
          <li><strong>تأسيس الشركات</strong> — SARL أو SARLAU أو SAS، من الهيكل القانوني إلى التسجيل. انظر <a href="/services/creation-entreprise">إنشاء المقاولة</a>.</li>
          <li><strong>التأسيس والامتثال في المناطق الحرّة</strong> — <a href="/zones/tanger-free-zone">المنطقة الحرّة بطنجة</a> و<a href="/zones/tanger-med">طنجة المتوسط</a> ومدينة السيارات وطنجة تك: النظام التفضيلي مُطبَّقًا بإتقان.</li>
          <li><strong>المحاسبة المُسنَدة (Externalisation)</strong> — مسك محاسبي كامل مع تقارير شهرية إلى مقرّكم الرئيسي. انظر <a href="/services/externalisation-comptable">إسناد المحاسبة</a>.</li>
          <li><strong>الاستشارة الجبائية</strong> — ضريبة الشركات (IS) والضريبة على القيمة المضافة والتحسين الجبائي في إطار القانون: <a href="/services/conseil-fiscal">الاستشارة الجبائية</a>.</li>
          <li><strong>الأجور والتغطية الاجتماعية</strong> — كشوف الأجور وتصاريح CNSS لفريقكم بالمغرب.</li>
          <li><strong>مكتب الصرف وأرباح الأسهم</strong> — الامتثال في مجال العملة وإعادة تحويل الأرباح قانونيًا إلى الشريك الأجنبي.</li>
        </ul>

        <h2>لماذا طنجة</h2>
        <p>طنجة بوّابة بين أوروبا وإفريقيا، وموطن <a href="/zones/tanger-med">طنجة المتوسط</a> — أكبر ميناء في إفريقيا — وعدّة مناطق حرّة بنظام جبائي وجمركي تفضيلي. بالنسبة للمستثمر الأجنبي، تجمع بين القرب وميزة التكلفة وإطار داعم للأعمال. نساعدكم على الاستفادة منها دون أي خطأ في الامتثال.</p>

        <h2>كيف نعمل مع العملاء الدوليين</h2>
        <p>كل شيء رقمي ومتوافق مع العمل عن بُعد: ترسلون مستنداتكم عبر مساحة عمل مشتركة، فنعالجها ونودعها، وتتلقّون قوائم شهرية واضحة ولوحة متابعة. لكم مُحاوِر واحد متفرّغ يعرف ملفّكم ويردّ بسرعة. أتعابنا شفّافة ومحدّدة مسبقًا؛ انظر <a href="/tarifs">أسعارنا</a>.</p>

        <p>هل تفكّرون في الاستثمار أو تزاولون نشاطكم فعلًا في طنجة؟ الاستشارة الأولى مجانية. لدينا أيضًا دليل مخصّص <a href="/expat">للمغتربين والشركاء الأجانب</a>.</p>
        <p><a href="/contact">← احجزوا استشارة أولى مجانية</a></p>
      </div>
    </div>
  </section>
  <FAQ items={faq} />
</Page>
