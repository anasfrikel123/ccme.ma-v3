---
import Page from '~/layouts/Page.astro';
import { getCollection } from 'astro:content';
import { collectionPageSchema } from '~/lib/collection-schema';

const SITE = 'https://ccme.ma';
const posts = (await getCollection('blog')).sort((a, b) =>
  new Date(b.data.publishedTime).getTime() - new Date(a.data.publishedTime).getTime()
);
const hubSchema = collectionPageSchema({
  url: `${SITE}/blog`,
  name: 'Le Journal CCME — Blog expert-comptable Tanger',
  description: 'Articles pratiques comptabilité, fiscalité IS 2026, paie CNSS, juridique et création d\'entreprise au Maroc.',
  items: posts.map((p) => ({ url: `/blog/${p.id}`, name: p.data.title })),
});
const cats = [...new Set(posts.map(p => p.data.category))];

// Latest post becomes the featured card; rest go in the grid below.
const [featured, ...rest] = posts;

// Estimate reading time from raw markdown body for each post.
const readMinutes = (body: string | undefined): number => {
  const clean = (body ?? '').replace(/```[\s\S]*?```/g, ' ').replace(/[#>*_`\[\]\(\)\-]/g, ' ');
  const words = clean.split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 220));
};
const featuredMinutes = featured ? readMinutes(featured.body) : 0;
const restMinutes = new Map(rest.map(p => [p.id, readMinutes(p.body)]));

const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' });
---
<Page
  title="Blog expert-comptable Tanger : fiscalité & PME — CCME"
  description="Conseils pratiques sur la comptabilité, l'IS 2026, la TVA, la paie CNSS et la création d'entreprise au Maroc. Décodés par un cabinet OEC à Tanger."
  eyebrow="Le Journal"
  heading="Comprendre les chiffres, sans le jargon."
  lede="Articles pratiques pour entrepreneurs, dirigeants et expatriés. Réforme IS 2026, contrôles fiscaux, zones franches, paie CNSS — tout ce qui concerne votre activité au Maroc."
  breadcrumb={[{ label: 'Accueil', href: '/' }, { label: 'Le Journal' }]}
  schema={hubSchema}
>
  {featured && (
    <section class="featured-section section-tight">
      <div class="container">
        <p class="eyebrow eyebrow-gold reveal">À la une</p>
        <article class="featured-card reveal">
          <a href={`/blog/${featured.id}`}>
            {featured.data.heroImage && (
              <div class="featured-thumb">
                <picture>
                  <source srcset={featured.data.heroImage.replace(/\.jpe?g$/i, '.webp')} type="image/webp" />
                  <img
                    src={featured.data.heroImage}
                    alt={`${featured.data.title} — illustration de l'article`}
                    loading="eager"
                    decoding="async"
                    width="1200"
                    height="675"
                    fetchpriority="high"
                  />
                </picture>
                <span class="featured-thumb-overlay" aria-hidden="true"></span>
              </div>
            )}
            <div class="featured-body">
              <div class="featured-meta">
                <span class="tag tag-gold">{featured.data.category}</span>
                <time datetime={featured.data.publishedTime}>{fmtDate(featured.data.publishedTime)}</time>
                <span class="featured-meta-dot" aria-hidden="true">·</span>
                <span>{featuredMinutes} min</span>
              </div>
              <h2>{featured.data.title}</h2>
              <p class="featured-desc">{featured.data.description}</p>
              <span class="featured-cta">
                <span>Lire l'article</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </span>
            </div>
          </a>
        </article>
      </div>
    </section>
  )}

  <section>
    <div class="container">
      <div class="cat-filter reveal" role="group" aria-label="Filtrer les articles par catégorie">
        <button
          class="cat-pill active"
          data-filter="all"
          type="button"
          aria-pressed="true"
        >Tout</button>
        {cats.map(c => (
          <button
            class="cat-pill"
            data-filter={c}
            type="button"
            aria-pressed="false"
          >{c}</button>
        ))}
      </div>

      <div
        class="post-grid"
        id="post-grid"
        aria-live="polite"
      >
        {rest.map((p, i) => (
          <article class="post-card reveal" data-cat={p.data.category} style={`transition-delay:${i * 50}ms`}>
            <a href={`/blog/${p.id}`}>
              {p.data.heroImage && (
                <div class="post-thumb">
                  <picture>
                    <source srcset={p.data.heroImage.replace(/\.jpe?g$/i, '.webp')} type="image/webp" />
                    <img
                      src={p.data.heroImage}
                      alt={`${p.data.title} — illustration de l'article`}
                      loading="lazy"
                      decoding="async"
                      width="600"
                      height="338"
                    />
                  </picture>
                  <span class="post-thumb-tint" aria-hidden="true"></span>
                </div>
              )}
              <div class="post-body">
                <div class="post-meta">
                  <span class="tag tag-gold">{p.data.category}</span>
                  <span class="post-meta-right">
                    <time datetime={p.data.publishedTime}>{fmtDate(p.data.publishedTime)}</time>
                    <span class="post-meta-dot" aria-hidden="true">·</span>
                    <span>{restMinutes.get(p.id)} min</span>
                  </span>
                </div>
                <h3>{p.data.title}</h3>
                <p>{p.data.description}</p>
                <span class="post-cta">
                  <span>Lire</span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Page>

<script>
  const pills = Array.from(document.querySelectorAll<HTMLButtonElement>('.cat-pill'));
  const cards = document.querySelectorAll<HTMLElement>('.post-card');

  function activate(target: HTMLButtonElement) {
    pills.forEach(x => {
      const isActive = x === target;
      x.classList.toggle('active', isActive);
      x.setAttribute('aria-pressed', isActive ? 'true' : 'false');
    });
    const f = target.dataset.filter;
    cards.forEach(c => {
      const show = f === 'all' || c.dataset.cat === f;
      c.hidden = !show;
    });
  }

  pills.forEach(p => {
    p.addEventListener('click', () => activate(p));
  });
</script>

<style>
  /* ── Featured / hero post ──────────────────────────────────── */
  .featured-section { padding-block: clamp(20px, 3vw, 32px) clamp(24px, 4vw, 40px); }
  .featured-section .eyebrow { margin-bottom: 16px; }
  .featured-card {
    border-radius: var(--r-xl);
    overflow: hidden;
    background: #fff;
    border: 1px solid var(--line);
    box-shadow: 0 18px 40px -22px rgba(20, 37, 63, 0.18);
    transition: box-shadow .35s ease, transform .35s cubic-bezier(0.34, 1.56, 0.64, 1), border-color .35s ease;
  }
  .featured-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in oklch, var(--gold) 35%, var(--line));
    box-shadow: 0 28px 56px -24px rgba(20, 37, 63, 0.28);
  }
  .featured-card a {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    text-decoration: none;
    color: var(--ink);
    align-items: stretch;
  }
  .featured-thumb {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 11;
    background: var(--paper-2);
  }
  .featured-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .9s cubic-bezier(.2,.8,.2,1);
  }
  .featured-card:hover .featured-thumb img { transform: scale(1.04); }
  .featured-thumb-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(380px 240px at 0% 100%, rgba(20, 37, 63, 0.18), transparent 55%);
    pointer-events: none;
  }
  .featured-body {
    padding: clamp(28px, 4vw, 48px);
    display: flex;
    flex-direction: column;
    gap: 14px;
    justify-content: center;
  }
  .featured-meta {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--muted);
  }
  .featured-meta time { font-weight: 600; color: var(--ink-soft); }
  .featured-meta-dot { color: color-mix(in oklch, var(--gold) 60%, var(--muted)); }
  .featured-card h2 {
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    line-height: 1.2;
    margin: 0;
    text-wrap: balance;
    transition: color .25s ease;
  }
  .featured-card:hover h2 { color: var(--accent-2); }
  .featured-desc {
    color: var(--ink-soft);
    font-size: 1rem;
    line-height: 1.55;
    margin: 0;
  }
  .featured-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--gold);
    font-weight: 600;
    font-size: 14px;
    margin-top: 4px;
    transition: gap .3s ease;
  }
  .featured-card:hover .featured-cta { gap: 16px; }

  /* ── Filter pills ──────────────────────────────────────────── */
  .cat-filter {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 36px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }
  .cat-pill {
    padding: 9px 18px;
    border-radius: 999px;
    background: transparent;
    border: 1px solid var(--line);
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    color: var(--ink-soft);
    transition: all var(--t-fast);
    font-family: inherit;
    position: relative;
  }
  .cat-pill:hover { border-color: var(--ink); color: var(--ink); }
  .cat-pill:focus-visible { outline: 2px solid var(--gold); outline-offset: 3px; }
  .cat-pill.active {
    background: linear-gradient(135deg, var(--gold) 0%, #d4a857 100%);
    color: #2a1f04;
    border-color: transparent;
    box-shadow: 0 6px 18px -6px rgba(196, 154, 70, 0.55);
  }

  /* ── Tag (gold variant for category labels) ──────────────── */
  .tag-gold {
    background: color-mix(in oklch, var(--gold) 14%, transparent);
    border-color: color-mix(in oklch, var(--gold) 35%, var(--line));
    color: var(--accent-deep);
  }

  /* ── Post grid ─────────────────────────────────────────────── */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: clamp(20px, 2vw, 28px);
  }
  .post-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    transition:
      transform .4s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow .35s ease,
      border-color .35s ease;
    overflow: hidden;
    isolation: isolate;
  }
  .post-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 28px 50px -22px rgba(20, 37, 63, 0.22);
    border-color: color-mix(in oklch, var(--gold) 35%, var(--line));
  }
  .post-card[hidden] { display: none; }
  .post-card a {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--ink);
    height: 100%;
  }
  .post-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--paper-2);
  }
  .post-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .8s cubic-bezier(.2,.8,.2,1);
  }
  .post-card:hover .post-thumb img { transform: scale(1.06); }
  /* Soft warm tint that blooms on hover */
  .post-thumb-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(20, 37, 63, 0.18) 100%);
    opacity: 0.5;
    transition: opacity .35s ease;
    pointer-events: none;
  }
  .post-card:hover .post-thumb-tint { opacity: 1; }

  .post-body {
    display: flex;
    flex-direction: column;
    padding: 22px 24px 26px;
    flex: 1;
    gap: 10px;
  }
  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
    font-size: 12.5px;
    color: var(--muted);
  }
  .post-meta-right {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--muted);
    white-space: nowrap;
  }
  .post-meta-dot { color: color-mix(in oklch, var(--gold) 60%, var(--muted)); }

  .post-card h3 {
    font-size: 1.18rem;
    line-height: 1.3;
    margin: 0;
    color: var(--ink);
    transition: color .25s ease;
    text-wrap: balance;
  }
  .post-card:hover h3 { color: var(--accent-2); }
  .post-card p {
    color: var(--ink-soft);
    font-size: 14.5px;
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }
  .post-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--gold);
    font-weight: 600;
    font-size: 13.5px;
    margin-top: 8px;
    transition: gap .3s ease, color .25s ease;
  }
  .post-card:hover .post-cta { gap: 12px; }

  @media (max-width: 880px) {
    .featured-card a { grid-template-columns: 1fr; }
    .featured-thumb { aspect-ratio: 16 / 9; }
    .featured-card h2 { font-size: clamp(1.4rem, 5vw, 1.85rem); }
  }
</style>
