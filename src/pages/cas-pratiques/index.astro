---
import Page from '~/layouts/Page.astro';
import { getCollection } from 'astro:content';
import { collectionPageSchema } from '~/lib/collection-schema';

const SITE = 'https://ccme.ma';
const cases = (await getCollection('cas')).sort((a, b) =>
  new Date(b.data.publishedTime).getTime() - new Date(a.data.publishedTime).getTime()
);

const hubSchema = collectionPageSchema({
  url: `${SITE}/cas-pratiques`,
  name: 'Cas pratiques — Résultats clients CCME',
  description: 'Études de cas anonymisées : optimisations fiscales, contrôles DGI, créations d\'entreprise et passages SARL pour clients réels du cabinet à Tanger.',
  items: cases.map((c) => ({ url: `/cas-pratiques/${c.id}`, name: c.data.title })),
});

const sectors = [...new Set(cases.map(c => c.data.sector))];

const slugify = (s: string) => s.toLowerCase()
  .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
  .replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' });

// Pull the first quantified outcome to render a headline KPI on each card.
const headlineOutcome = (c: typeof cases[number]) => c.data.outcomes[0];
---
<Page
  title="Cas pratiques : résultats clients réels — CCME Tanger"
  description="Études de cas anonymisées : optimisations IS, contrôles fiscaux résolus, créations SARL express, crédits TVA débloqués. Chiffres réels et méthode."
  eyebrow="Cas pratiques"
  heading="Les chiffres parlent plus fort que les promesses."
  lede="Études de cas anonymisées tirées de notre portefeuille client. Chaque dossier détaille la situation initiale, la méthode appliquée et les résultats mesurés. Aucun chiffre inventé, aucune promesse marketing."
  breadcrumb={[{ label: 'Accueil', href: '/' }, { label: 'Cas pratiques' }]}
  schema={hubSchema}
>
  <section>
    <div class="container">
      <div class="cas-stats reveal">
        <div class="cas-stat">
          <strong>+15 ans</strong>
          <span>d'expérience cumulée</span>
        </div>
        <div class="cas-stat">
          <strong>180+</strong>
          <span>dossiers actifs PME / Expat</span>
        </div>
        <div class="cas-stat">
          <strong>0</strong>
          <span>redressement majeur en 2025</span>
        </div>
      </div>

      {sectors.length > 1 && (
        <div class="cat-filter reveal" role="tablist" aria-label="Filtrer les cas par secteur">
          <button
            class="cat-pill active"
            data-filter="all"
            role="tab"
            aria-selected="true"
            aria-controls="cas-grid"
            id="cas-tab-all"
            type="button"
          >Tous secteurs</button>
          {sectors.map(s => (
            <button
              class="cat-pill"
              data-filter={s}
              role="tab"
              aria-selected="false"
              aria-controls="cas-grid"
              id={`cas-tab-${slugify(s)}`}
              type="button"
              tabindex="-1"
            >{s}</button>
          ))}
        </div>
      )}

      <div
        class="cas-grid"
        id="cas-grid"
        role="tabpanel"
        aria-live="polite"
        aria-labelledby="cas-tab-all"
      >
        {cases.map((c, i) => {
          const kpi = headlineOutcome(c);
          return (
            <article class="cas-card reveal" data-cat={c.data.sector} style={`transition-delay:${i * 60}ms`}>
              <a href={`/cas-pratiques/${c.id}`} aria-label={`Voir le cas : ${c.data.title}`}>
                <div class="cas-body">
                  <div class="cas-meta">
                    <span class="tag tag-gold">{c.data.sector}</span>
                    {c.data.zone && <span class="cas-zone">{c.data.zone}</span>}
                  </div>

                  <h2>{c.data.title}</h2>

                  <p class="cas-profile">{c.data.profile}</p>

                  <div class="cas-kpi" aria-hidden="true">
                    <div class="cas-kpi-label">{kpi.label}</div>
                    <div class="cas-kpi-flow">
                      <span class="cas-kpi-before">{kpi.before}</span>
                      <svg width="22" height="14" viewBox="0 0 24 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="2" y1="7" x2="20" y2="7"></line>
                        <polyline points="14 1 20 7 14 13"></polyline>
                      </svg>
                      <span class="cas-kpi-after">{kpi.after}</span>
                    </div>
                    {kpi.delta && <div class="cas-kpi-delta">{kpi.delta}</div>}
                  </div>

                  <p class="cas-desc">{c.data.description}</p>

                  <div class="cas-footer">
                    <time datetime={c.data.publishedTime}>{fmtDate(c.data.publishedTime)}</time>
                    {c.data.duration && (
                      <>
                        <span class="cas-meta-dot" aria-hidden="true">·</span>
                        <span>Durée : {c.data.duration}</span>
                      </>
                    )}
                  </div>

                  <span class="cas-cta">
                    <span>Voir le cas complet</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </span>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>
</Page>

<script>
  const tablist = document.querySelector<HTMLElement>('.cat-filter');
  const pills = Array.from(document.querySelectorAll<HTMLButtonElement>('.cat-pill'));
  const cards = document.querySelectorAll<HTMLElement>('.cas-card');
  const grid = document.getElementById('cas-grid');

  function activate(target: HTMLButtonElement) {
    pills.forEach(x => {
      const isActive = x === target;
      x.classList.toggle('active', isActive);
      x.setAttribute('aria-selected', isActive ? 'true' : 'false');
      x.setAttribute('tabindex', isActive ? '0' : '-1');
    });
    grid?.setAttribute('aria-labelledby', target.id);
    const f = target.dataset.filter;
    cards.forEach(c => {
      const show = f === 'all' || c.dataset.cat === f;
      c.hidden = !show;
    });
  }

  pills.forEach(p => p.addEventListener('click', () => activate(p)));

  tablist?.addEventListener('keydown', (e) => {
    const current = pills.findIndex(p => p === document.activeElement);
    if (current === -1) return;
    let next = current;
    if (e.key === 'ArrowRight') next = (current + 1) % pills.length;
    else if (e.key === 'ArrowLeft') next = (current - 1 + pills.length) % pills.length;
    else if (e.key === 'Home') next = 0;
    else if (e.key === 'End') next = pills.length - 1;
    else return;
    e.preventDefault();
    pills[next]?.focus();
    activate(pills[next]);
  });
</script>

<style>
  /* ── Trust band ───────────────────────────────────────────── */
  .cas-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: clamp(16px, 2vw, 28px);
    padding: clamp(22px, 3vw, 30px) clamp(22px, 4vw, 36px);
    margin-bottom: clamp(28px, 4vw, 44px);
    border-radius: var(--r-xl);
    background: linear-gradient(135deg, color-mix(in oklch, var(--gold) 8%, var(--paper-2)) 0%, var(--paper-2) 100%);
    border: 1px solid color-mix(in oklch, var(--gold) 22%, var(--line));
  }
  .cas-stat { display: flex; flex-direction: column; gap: 4px; }
  .cas-stat strong {
    font-family: var(--ff-serif, 'Newsreader', serif);
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    font-weight: 600;
    color: var(--accent-deep, var(--ink));
    line-height: 1.05;
  }
  .cas-stat span { color: var(--muted); font-size: 14px; }

  /* ── Filter pills (reuse from blog) ───────────────────────── */
  .cat-filter {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 36px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }
  .cat-pill {
    padding: 9px 18px;
    border-radius: 999px;
    background: transparent;
    border: 1px solid var(--line);
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    color: var(--ink-soft);
    transition: all var(--t-fast);
    font-family: inherit;
  }
  .cat-pill:hover { border-color: var(--ink); color: var(--ink); }
  .cat-pill:focus-visible { outline: 2px solid var(--gold); outline-offset: 3px; }
  .cat-pill.active {
    background: linear-gradient(135deg, var(--gold) 0%, #d4a857 100%);
    color: #2a1f04;
    border-color: transparent;
    box-shadow: 0 6px 18px -6px rgba(196, 154, 70, 0.55);
  }

  .tag-gold {
    background: color-mix(in oklch, var(--gold) 14%, transparent);
    border-color: color-mix(in oklch, var(--gold) 35%, var(--line));
    color: var(--accent-deep);
  }

  /* ── Card grid ────────────────────────────────────────────── */
  .cas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: clamp(20px, 2vw, 28px);
  }
  .cas-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    transition:
      transform .4s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow .35s ease,
      border-color .35s ease;
    overflow: hidden;
    position: relative;
  }
  .cas-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold) 0%, transparent 100%);
    transform-origin: left;
    transform: scaleX(0);
    transition: transform .45s ease;
  }
  .cas-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 22px 48px -22px rgba(20, 37, 63, 0.22);
    border-color: color-mix(in oklch, var(--gold) 35%, var(--line));
  }
  .cas-card:hover::before { transform: scaleX(1); }
  .cas-card a {
    display: block;
    text-decoration: none;
    color: var(--ink);
    height: 100%;
  }
  .cas-body {
    padding: clamp(22px, 3vw, 30px);
    display: flex;
    flex-direction: column;
    gap: 14px;
    height: 100%;
  }
  .cas-meta { display: inline-flex; flex-wrap: wrap; gap: 10px; align-items: center; }
  .cas-zone {
    font-size: 13px;
    color: var(--muted);
    font-weight: 500;
  }
  .cas-card h2 {
    font-size: clamp(1.15rem, 1.8vw, 1.35rem);
    line-height: 1.3;
    margin: 0;
    text-wrap: balance;
    transition: color .25s ease;
  }
  .cas-card:hover h2 { color: var(--accent-2); }
  .cas-profile {
    color: var(--muted);
    font-size: 13.5px;
    line-height: 1.5;
    margin: 0;
    font-style: italic;
  }

  /* KPI tile — the visual hook on each card */
  .cas-kpi {
    background: linear-gradient(135deg, color-mix(in oklch, var(--gold) 6%, var(--paper-2)) 0%, var(--paper-2) 100%);
    border: 1px solid color-mix(in oklch, var(--gold) 22%, var(--line));
    border-radius: var(--r-md);
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .cas-kpi-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .cas-kpi-flow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    color: var(--ink-soft);
  }
  .cas-kpi-before {
    text-decoration: line-through;
    color: var(--muted);
    font-size: 14px;
  }
  .cas-kpi-flow svg { color: var(--gold); flex-shrink: 0; }
  .cas-kpi-after {
    font-weight: 700;
    font-size: 16px;
    color: var(--ink);
  }
  .cas-kpi-delta {
    align-self: flex-start;
    font-size: 12px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 999px;
    background: color-mix(in oklch, var(--gold) 18%, transparent);
    color: var(--accent-deep);
  }

  .cas-desc {
    color: var(--ink-soft);
    font-size: 14.5px;
    line-height: 1.55;
    margin: 0;
  }
  .cas-footer {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12.5px;
    color: var(--muted);
    margin-top: auto;
    padding-top: 6px;
  }
  .cas-meta-dot { color: color-mix(in oklch, var(--gold) 60%, var(--muted)); }

  .cas-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    color: var(--gold);
    font-weight: 600;
    font-size: 14px;
    transition: gap .3s ease;
  }
  .cas-card:hover .cas-cta { gap: 14px; }

  @media (max-width: 600px) {
    .cas-stats { padding: 18px 20px; }
  }
</style>
