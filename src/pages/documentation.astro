---
import Page from '~/layouts/Page.astro';
import { DOC_GUIDES, DOC_GROUPS, OFFICIAL_LINKS } from '~/data/documentation';

const SITE = 'https://www.ccme.ma';
---
<Page
  title="Documentation fiscale & guides entrepreneur 2026 — CCME"
  description="Guides pratiques, synthèses Loi de Finances 2026, CGI, communiqués DGI et liens vers les portails officiels marocains. Ressources CCME Tanger."
  eyebrow="Ressources"
  heading="Documentation & outils."
  lede="Guides pratiques, synthèses de la Loi de Finances 2026, textes fiscaux officiels, notes circulaires, communiqués DGI et jurisprudence à télécharger, plus les liens vers les portails institutionnels marocains."
  breadcrumb={[{ label: 'Accueil', href: '/' }, { label: 'Documentation' }]}
  keywords={['documentation fiscale Maroc', 'CGI 2026 PDF', 'Loi de Finances 2026', 'guides entrepreneur Maroc']}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Documentation CCME',
    url: `${SITE}/documentation`,
    description: 'Ressources fiscales et guides pratiques CCME pour entreprises marocaines à Tanger.',
    publisher: { '@id': 'https://www.ccme.ma/#accounting' },
  }}
>
  <section>
    <div class="container">
      <div class="sec-head reveal">
        <span class="eyebrow">Guides & synthèses</span>
        <h2 class="headline docs-headline">Ressources pour décider et se mettre en conformité.</h2>
      </div>

      <div class="doc-guides">
        {DOC_GUIDES.map((g) => (
          <article class="doc-guide reveal" id={`guide-${g.id}`}>
            <span class="doc-guide-tag">{g.tag}</span>
            <h3 class="doc-guide-title">{g.title}</h3>
            <p class="doc-guide-summary">{g.summary}</p>
            <div class="doc-guide-body">
              {g.sections.map((s) => (
                <div class="doc-guide-section">
                  <h4>{s.h}</h4>
                  <p>{s.p}</p>
                </div>
              ))}
            </div>
            <div class="doc-guide-refs">
              <span class="doc-guide-refs-label">Documents & pages liés</span>
              {g.refs.map((r) => (
                <a
                  class="doc-guide-ref"
                  href={r.href}
                  {...(r.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {r.label}<span aria-hidden="true"> →</span>
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>

      <div class="sec-head reveal docs-downloads-head">
        <span class="eyebrow">Téléchargements</span>
        <h2 class="headline docs-headline">Textes officiels & communiqués.</h2>
      </div>

      {DOC_GROUPS.map((g) => (
        <div class="doc-group reveal">
          <h3 class="doc-h">{g.title}</h3>
          <div class="doc-list">
            {g.items.map((it) => (
              <a class="doc-row" href={it.href} target="_blank" rel="noopener noreferrer">
                <span class="doc-ic" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6">
                    <path d="M6 2.5h8l4 4V21a.5.5 0 01-.5.5h-11A.5.5 0 016 21z" />
                    <path d="M14 2.5V7h4" />
                  </svg>
                </span>
                <span class="doc-info"><b>{it.name}</b><span>{it.format}</span></span>
                <span class="doc-dl" aria-hidden="true">↓</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="docs-portals">
    <div class="container">
      <div class="sec-head reveal">
        <span class="eyebrow">Liens utiles</span>
        <h2 class="headline">Portails officiels.</h2>
      </div>
      <div class="links-grid reveal">
        {OFFICIAL_LINKS.map((l) => (
          <a class="link-card" href={l.url} target="_blank" rel="noopener">
            <b>{l.name}</b>
            <span class="lc-go" aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Page>

<style>
  .docs-headline { font-size: clamp(26px, 3vw, 40px); }
  .docs-downloads-head { margin-top: 56px; margin-bottom: 8px; }
  .docs-portals { padding-top: 0; padding-bottom: clamp(48px, 6vw, 80px); }
  .docs-portals .container { padding-top: clamp(48px, 6vw, 80px); }
</style>
