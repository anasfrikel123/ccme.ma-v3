---
import Page from '~/layouts/Page.astro';
---
<Page
  title="Calcul TVA Maroc | HT/TTC, taux 20/14/10/7%"
  description="Calcul TVA Maroc gratuit. Conversion HT en TTC et inversement, tous les taux : 20%, 14%, 10%, 7%. Outil instantané."
  eyebrow="Outil"
  heading="Calcul TVA Maroc"
  lede="HT vers TTC, TTC vers HT, tous les taux marocains : 20 % (standard), 14 % (BTP, transport), 10 % (tourisme), 7 % (eau, électricité, médicaments)."
  breadcrumb={[{ label: 'Accueil', href: '/' }, { label: 'Outils', href: '/outils' }, { label: 'Calcul TVA' }]}
  keywords={["calcul TVA Maroc","HT TTC TVA","convertisseur TVA Maroc","taux TVA Maroc"]}
>
  <section>
    <div class="container narrow">
      <div class="card sim-card">
        <h2>Convertisseur TVA</h2>
        <div class="form-grid">
          <label>
            <span>Sens du calcul</span>
            <select id="sens">
              <option value="htttc">HT → TTC</option>
              <option value="ttcht">TTC → HT</option>
            </select>
          </label>
          <label>
            <span>Montant</span>
            <input type="number" id="montant" min="0" step="0.01" placeholder="Ex : 1 000" />
          </label>
          <label>
            <span>Taux TVA</span>
            <select id="taux">
              <option value="0.20">20 % — Taux normal</option>
              <option value="0.14">14 % — BTP, transport</option>
              <option value="0.10">10 % — Tourisme, restauration</option>
              <option value="0.07">7 % — Eau, électricité, médicaments</option>
              <option value="0">0 % — Exonéré</option>
            </select>
          </label>
        </div>
        <button id="calculate" class="btn btn-gold" type="button">Calculer</button>

        <p id="sim-error" class="sim-error" role="alert" aria-live="polite"></p>

        <div id="result" class="result" hidden>
          <div class="row"><span>HT</span><strong id="rHt">—</strong></div>
          <div class="row"><span>TVA</span><strong id="rTva">—</strong></div>
          <div class="row total"><span>TTC</span><strong id="rTtc">—</strong></div>
        </div>
      </div>
    </div>
  </section>
</Page>

<style>
  .narrow { max-width: 700px; }
  .sim-card { padding: 32px; }
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 24px 0; }
  .form-grid label:first-child { grid-column: 1 / -1; }
  .form-grid span { display: block; font-size: 13px; font-weight: 600; color: var(--ink-soft); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.04em; }
  .form-grid input, .form-grid select { width: 100%; padding: 14px 16px; border: 1px solid var(--line); border-radius: var(--r-md); font-size: 16px; background: #fff; }
  .form-grid input:focus, .form-grid select:focus { outline: 2px solid var(--gold); }
  .result { margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--line); }
  .row { display: flex; justify-content: space-between; padding: 10px 0; font-size: 15px; }
  .row strong { font-variant-numeric: tabular-nums; }
  .row.total { padding: 14px 0; border-top: 1px solid var(--ink); margin-top: 8px; font-weight: 700; font-size: 17px; }
  .row.total strong { color: var(--gold); font-size: 22px; }
  @media (max-width: 600px) { .form-grid { grid-template-columns: 1fr; } }
  .sim-error { color: #b3261e; font-size: 14px; min-height: 1.4em; margin: 12px 0 0; font-weight: 500; }
  .sim-error:empty { display: none; }
</style>

<script>
  import { computeTVA, fmtDH2, type TvaDirection } from '~/lib/tax-maroc';
  document.getElementById('calculate')!.addEventListener('click', () => {
    const errEl = document.getElementById('sim-error') as HTMLElement;
    errEl.textContent = '';
    const sens = (document.getElementById('sens') as HTMLSelectElement).value as TvaDirection;
    const montant = parseFloat((document.getElementById('montant') as HTMLInputElement).value) || 0;
    const taux = parseFloat((document.getElementById('taux') as HTMLSelectElement).value);
    if (montant <= 0) {
      errEl.textContent = 'Veuillez saisir un montant supérieur à 0.';
      (document.getElementById('montant') as HTMLInputElement).focus();
      return;
    }
    const r = computeTVA(montant, taux, sens);
    document.getElementById('rHt')!.textContent = fmtDH2(r.ht);
    document.getElementById('rTva')!.textContent = fmtDH2(r.tva);
    document.getElementById('rTtc')!.textContent = fmtDH2(r.ttc);
    (document.getElementById('result') as HTMLElement).hidden = false;
  });
</script>
